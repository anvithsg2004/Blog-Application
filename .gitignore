# =========================================================
# Repo-wide .gitignore  (Blog-Frontend + Blog-Backend)
# =========================================================

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# --- Node / Frontend ---
node_modules/
**/node_modules/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp.*
.cache/

# Vite build output — never commit, Netlify rebuilds on push
Blog-Frontend/dist/
**/dist/

# Local Netlify state
.netlify/
**/.netlify/

# --- Environment / secrets ---
# NEVER commit real .env files. Only .env.example is safe to commit.
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# --- Java / Maven / Backend ---
Blog-Backend/target/
**/target/
*.class
*.jar
*.war
*.iml
hs_err_pid*.log

# Spring Boot dev tools
.spring-boot-devtools-restart-included

# --- Misc ---
.claude/
*.tmp
