# Copy this file to .env (or .env.local) and fill in your values.
# .env is gitignored — these secrets stay on your machine.

# ---------------------------------------------------------------
# Groq API key — used by netlify/functions/summarize.js and qa.js
# ---------------------------------------------------------------
# Get one (free, no card required) at https://console.groq.com/keys
# Free tier on the default model (llama-3.1-8b-instant):
#   - 30 requests / minute
#   - 14,400 requests / day
#   - sub-second response times, no cold starts
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — override the model. Defaults to "llama-3.1-8b-instant".
# Heavier alternatives (lower daily quota): "llama-3.3-70b-versatile"
# GROQ_MODEL=llama-3.1-8b-instant

# ---------------------------------------------------------------
# Backend API base URL — used by src/services/authService.js
# ---------------------------------------------------------------
# Leave unset to use the smart default:
#   - dev  (npm run dev)   → http://localhost:8080
#   - prod (vite build)    → https://blogs-backend-w9x0.onrender.com
# Set this only if you want to override the default in either env.
# VITE_API_BASE_URL=
